# ===============================================
# SubMind — Environment Configuration
# Copy this file to .env and fill in your paths
# ===============================================

# ── Find your Chrome path ──────────────────────
# Windows PowerShell:
#   Get-Command chrome | Select-Object -ExpandProperty Source
# Windows CMD:
#   where chrome
# Linux:
#   which google-chrome || which chromium-browser
# Mac:
#   mdfind -name "Google Chrome" | grep "\.app/Contents/MacOS"

CHROME_EXE=C:\Program Files\Google\Chrome\Application\chrome.exe

# ── Find your agent-browser path ──────────────
# Windows PowerShell:
#   Get-Command agent-browser | Select-Object -ExpandProperty Source
# Windows CMD:
#   where agent-browser
# Linux/Mac:
#   which agent-browser

AGENT_BROWSER=C:\Users\YourName\AppData\Roaming\npm\agent-browser.cmd

# ── Chrome profile directories ─────────────────
# These folders will be created automatically on first run.
# Just set paths where you want them stored.

CHATGPT_PROFILE=C:\Users\YourName\submind-chatgpt-profile
GEMINI_PROFILE=C:\Users\YourName\submind-gemini-profile

# ── Download and output paths ──────────────────
# These folders will be created automatically on first run.

GEMINI_DOWNLOAD_PATH=C:\Users\YourName\submind\gemini\docs
CHATGPT_IMAGES_PATH=C:\Users\YourName\submind\chatgpt_images

# ── Gemini extension path (bundled, usually leave as default) ──
# GEMINI_EXTENSION_PATH=.\gemini\extension

# ── PostgreSQL connection (memory tools) ───────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/llm_memory

# ── Optional: Groq API key (for browser_agent.py LLM router) ──
# GROQ_API_KEY=
